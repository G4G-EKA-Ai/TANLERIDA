# =============================================================================
# TANLERIDA - Google Cloud Platform Environment Variables
# Copy to .env.gcp and fill in your values
# =============================================================================

# =============================================================================
# GOOGLE CLOUD PROJECT
# =============================================================================
GOOGLE_CLOUD_PROJECT=tangred-ecommerce
GOOGLE_CLOUD_REGION=asia-south1
GOOGLE_CLOUD_ZONE=asia-south1-a

# =============================================================================
# CLOUD SQL (POSTGRESQL)
# =============================================================================
# Format: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/CONNECTION_NAME
DATABASE_URL="postgresql://tangred_app:YOUR_PASSWORD@/tangred_db?host=/cloudsql/tangred-ecommerce:asia-south1:tangred-postgres"

# For local development with Cloud SQL Proxy
DATABASE_URL_LOCAL="postgresql://tangred_app:YOUR_PASSWORD@localhost:5432/tangred_db"

# Cloud SQL Instance Connection Name
CLOUD_SQL_CONNECTION_NAME="tangred-ecommerce:asia-south1:tangred-postgres"

# =============================================================================
# FIREBASE
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tangred-ecommerce.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tangred-ecommerce
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tangred-ecommerce.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# =============================================================================
# CLOUD RUN BACKEND
# =============================================================================
# This is the URL of your deployed Cloud Run service
NEXT_PUBLIC_API_URL=https://tangred-api-xyz123-el.a.run.app
FRONTEND_URL=https://tangred.in

# =============================================================================
# AUTHENTICATION
# =============================================================================
AUTH_SECRET="your-super-secret-auth-key-generate-with-openssl-rand-base64-32"

# Google OAuth (set in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# =============================================================================
# AI SERVICES
# =============================================================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=tangred-products

# =============================================================================
# FILE STORAGE (CLOUDINARY)
# =============================================================================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# =============================================================================
# PAYMENTS (RAZORPAY)
# =============================================================================
RAZORPAY_KEY_ID=rzp_live_your_live_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_live_key

# =============================================================================
# EMAIL (RESEND)
# =============================================================================
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@tangred.in
REPLY_TO_EMAIL=support@tangred.in

# =============================================================================
# TAN LEIDA PRICING
# =============================================================================
TAN_LEIDA_PRICE_PAISE=9900
TAN_LEIDA_GST_PAISE=1782
TAN_LEIDA_TOTAL_PAISE=11682

# =============================================================================
# MONITORING (OPTIONAL)
# =============================================================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
